# MoleculeOS Form Server - Environment Variables
# Copy this to .env and fill in your credentials

# Feishu Open Platform App Credentials
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# Feishu Group Bot Webhook URL (for notifications)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/hook/your_webhook_id

# Feishu Spreadsheet Config
SPREADSHEET_APP_TOKEN=Ex7js7bjhh5elAtrlm1cPsd4nTd
SPREADSHEET_SHEET_ID=

# Feishu Bitable Config (fallback if spreadsheet fails)
BITABLE_APP_TOKEN=Ex7js7bjhh5elAtrlm1cPsd4nTd
BITABLE_TABLE_ID=

# Server Port
PORT=3000
